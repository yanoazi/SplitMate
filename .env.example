# SplitMate environment example — copy to .env

# 本機可不設，預設使用 SQLite ./splitmate.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/splitmate

# 你的公開網址（Railway 部署後改成 https://xxx.up.railway.app，不要結尾斜線）
PUBLIC_BASE_URL=http://localhost:7777

# LINE Bot（Web Demo 可不填；接群組記帳必填）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

DEMO_MODE=1
DEMO_TOKEN=demo
DEMO_EDIT_PIN=1234

SECRET_KEY=change-me-in-production
PORT=7777
